# Copy to backend/.env and set your OpenAI API key
OPENAI_API_KEY=sk-your-key-here

# Optional: persist vector DB under ./data/chroma
# CHROMA_PERSIST_DIR=./data/chroma

# Production (Render): comma-separated CORS origins for your frontend
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Optional: model selection (defaults: gpt-4o for summarization/QA, text-embedding-3-large)
# Use gpt-4o-mini for lower cost, gpt-4o for best quality
# SUMMARIZATION_MODEL=gpt-4o
# QA_MODEL=gpt-4o
# EMBEDDING_MODEL=text-embedding-3-large
